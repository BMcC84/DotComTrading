@page "/"
@page "/login"
@layout DotComTrading.UI.Components.Layout.LoginLayout

@*Login Page Allowing Users to Login Through Google*@

<PageTitle>Login</PageTitle>

<div class="login-page">
    <div class="background">
        <svg class="market-graph" viewBox="0 0 1200 300" preserveAspectRatio="none">
            <path d="M0 280
                L100 260
                L200 280
                L300 220
                L400 200
                L500 180
                L600 230
                L700 170
                L800 150
                L900 120
                L1000 140
                L1100 100
                L1200 80">
            </path>
        </svg>
    </div>
    <div class="login-card">
        <h1>DOT-COM TRADING</h1>
        <p class="tagline">A Game Of Websites</p>
        <p>Login or Create an Account.</p>
        <a class="google-btn" href="@GoogleLoginUrl">
            <img src="https://developers.google.com/identity/images/g-logo.png"/>
            <span>Continue with Google</span>
        </a>
    </div>
</div>

@code {
    private string GoogleLoginUrl = "https://localhost:7203/auth/google-login?returnUrl=https://localhost:7021/home"; //URL for redirecting users to backend endpoint
}

<style>

    .background {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        background-image: linear-gradient(rgba(0, 0, 0, 0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(0, 0, 0, 0.03) 1px, transparent 1px);
        background-size: 40px 40px;
        background-position: 20px 20px;
        z-index: 0;
    }

    .market-graph {
        position: absolute;
        width: 100%;
        height: 1000px;
        bottom: 0;
        left: 0;
        pointer-events: none;
        z-index: 0;
    }

    .market-graph path {
        fill: none;
        stroke: #4f46e5;
        stroke-width: 3;
        opacity: 0.60;
        stroke-dasharray: 1400;
        stroke-dashoffset: 1400;
        animation: drawGraph 4.0s ease forwards;
    }

    .login-page {
        min-height: 100vh;
        display: flex;
        position: relative;
        display: flex;
        overflow: hidden;
        justify-content: center;
        align-items: center;
    }

    .login-card{
        background: white;
        padding: 4rem;
        border-radius: 18px;
        box-shadow: 0 25px 50px rgba(0,0,0,0.08);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 20px;
        width: 600px;
        height: 400px;
        z-index: 1;
    }

    .login-card h1{
        margin-bottom: 10px;
        font-size: 28px;
    }

    .login-card p{
        margin-bottom: 25px;
        color: #666;
    }

    .tagline{
        font-size: 18px;
        font-weight: 500;
        color: #4f46e5;
        letter-spacing: 1px;
        margin-top: -5px;
    }

    .google-btn{
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 14px;
        width: 100%;
        padding: 16px;
        border-radius: 10px;
        border: 1px solid #dadce0;
        background: white;
        font-weight: 500;
        text-decoration: none;
        color: #3c4043;
        transition: all 0.2s ease, box-shadow 0.2s ease;
    }

    .google-btn img{
        width: 22px;
    }

    .google-btn:hover{
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        background: #fafafa;
    }

    @@keyframes drawGraph {
        to {
            stroke-dashoffset: 0;
        }
    }

</style>

