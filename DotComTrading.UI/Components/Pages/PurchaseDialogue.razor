@using DotComTrading.Models
@using Radzen

@inject DialogService DialogService

@*Dialog Component For Selecting Number of Shares to Purchase*@

<div style="padding:10px;">
	<p>How Many Shares Would You Like to Purchase?</p>
	<input type="number" class="form-control" min="0.01" step="0.01" @bind-value="Shares" @bind-value:event="oninput" />
		<p style="margin-top:15px">Total Price: <strong>£@PurchaseTotal.ToString("0.00")</strong></p>
	<div style="display:flex; gap:10px; justify-content:flex-end; margin-top:20px;">
		<button class="btn btn-secondary" @onclick="Cancel">Cancel</button>
		<button class="btn btn-success" @onclick="Confirm">Confirm Purchase</button>
	</div>
</div>

@code {
	[Parameter]
	public decimal WebsitePrice { get; set; }

	private decimal Shares { get; set; } = 1;

	private decimal PurchaseTotal
	{
		get
		{
			return WebsitePrice * Shares;
		}
	}

	private void Cancel()
	{
		DialogService.Close(null);
	}

	private void Confirm()
	{
		DialogService.Close(Shares);
	}
}
